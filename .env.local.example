# =============================================
# GiftWise — Environment Variables Example
# =============================================
# HD: Sao chép file này thành .env.local và điền giá trị key thật của bạn
# (File .env.local sẽ tự động bị git bỏ qua để bảo mật)

# --- 1. Anthropic Claude API Key (Khuyến khích cho AI tư vấn tốt nhất) ---
# Lấy key tại: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# Hoặc hỗ trợ nhiều key xoay vòng (phân cách bằng dấu phẩy):
# ANTHROPIC_API_KEYS=sk-ant-api03-key1,sk-ant-api03-key2

# --- 2. Google Gemini API Key (Dự phòng tự động nếu Claude hết dung lượng) ---
# Lấy key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyXxxx

# Hoặc hỗ trợ nhiều key xoay vòng (phân cách bằng dấu phẩy):
# GEMINI_API_KEYS=AIzaSyKey1,AIzaSyKey2

# --- 3. App Settings ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
